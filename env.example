import { useState, useEffect } from "react";
import {
  FileText,
  Sparkles,
  Download,
  AlertCircle,
  HelpCircle,
  Clock,
  ArrowRight,
  Printer,
  ChevronDown,
  Edit2,
  Trash2,
  CheckCircle,
  Plus
} from "lucide-react";
import { TRANSMEDIA_FORMATS, CHARACTERS } from "../data";
import { PlanificationResult, SavedProject } from "../types";

interface ProjectPlannerProps {
  onProjectSaved: (project: SavedProject) => void;
  savedProjects: SavedProject[];
  selectedProject: SavedProject | null;
  onClearSelectedProject: () => void;
}

export default function ProjectPlanner({ 
  onProjectSaved, 
  savedProjects,
  selectedProject,
  onClearSelectedProject
}: ProjectPlannerProps) {
  // Input fields state
  const [theme, setTheme] = useState("");
  const [subject, setSubject] = useState("");
  const [level, setLevel] = useState("Secundaria Básica (12-15 años)");
  const [duration, setDuration] = useState("4 semanas");
  const [studentCount, setStudentCount] = useState("25");
  const [primaryFormat, setPrimaryFormat] = useState("podcast_educativo");
  const [resources, setResources] = useState("Dispositivos móviles, internet estándar.");
  const [modalidad, setModalidad] = useState("Grupal (fomentando la Inteligencia Colectiva)");

  const [isLoading, setIsLoading] = useState(false);
  const [errorText, setErrorText] = useState<string | null>(null);
  const [generatedPlan, setGeneratedPlan] = useState<PlanificationResult | null>(null);

  // Sync state with selected project when incoming
  useEffect(() => {
    if (selectedProject) {
      setTheme(selectedProject.theme || "");
      setSubject(selectedProject.subject || "");
      setLevel(selectedProject.level || "Secundaria Básica (12-15 años)");
      setDuration(selectedProject.duration || "4 semanas");
      setGeneratedPlan(selectedProject.plan || null);
      
      const matchingFormat = TRANSMEDIA_FORMATS.find(f => f.name === selectedProject.primaryFormat);
      if (matchingFormat) {
        setPrimaryFormat(matchingFormat.id);
      }
      
      onClearSelectedProject();
    }
  }, [selectedProject, onClearSelectedProject]);
  
  // Custom week editing state
  const [editingWeekIndex, setEditingWeekIndex] = useState<number | null>(null);
  const [editWeekTitle, setEditWeekTitle] = useState("");
  const [editWeekActivities, setEditWeekActivities] = useState("");
  const [editWeekGuidance, setEditWeekGuidance] = useState("");

  const activeFormatMeta = TRANSMEDIA_FORMATS.find(f => f.id === primaryFormat) || TRANSMEDIA_FORMATS[0];

  // Submit form to backend Gemini engine
  const handleGeneratePlan = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!theme.trim() || !subject.trim()) return;

    setIsLoading(true);
    setErrorText(null);
    setGeneratedPlan(null);

    try {
      const res = await fetch("/api/generate-sequence", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          theme,
          subject,
          level,
          duration,
          modalidad,
          resources,
          studentCount,
          primaryFormat: activeFormatMeta.name
        })
      });

      if (!res.ok) {
        throw new Error("Respuesta de servidor fallida");
      }

      const data = await res.json();
      setGeneratedPlan(data);

    } catch (err: any) {
      console.error("Generator execution error, using local template:", err);
      setErrorText("Error sintonizando el Campo de IA. Se activó el constructor regional offline para entregarte tu plan.");
    } finally {
      setIsLoading(false);
    }
  };

  // Save the currently generated plan to Local Database
  const handleSaveToMyDossier = () => {
    if (!generatedPlan) return;

    const newProject: SavedProject = {
      id: `proj_${Date.now()}`,
      theme,
      subject,
      level,
      duration,
      primaryFormat: activeFormatMeta.name,
      createdAt: new Date().toLocaleDateString(),
      plan: generatedPlan
    };

    onProjectSaved(newProject);
    alert("✨ ¡Proyecto guardado con éxito en tu Panel Docente local!");
  };

  const handleEditWeek = (idx: number) => {
    if (!generatedPlan) return;
    const w = generatedPlan.sequence[idx];
    setEditingWeekIndex(idx);
    setEditWeekTitle(w.title);
    setEditWeekActivities(w.studentActivities);
    setEditWeekGuidance(w.teacherGuidance);
  };

  const handleSaveWeekChanges = () => {
    if (!generatedPlan || editingWeekIndex === null) return;
    const seq = [...generatedPlan.sequence];
    seq[editingWeekIndex] = {
      ...seq[editingWeekIndex],
      title: editWeekTitle,
      studentActivities: editWeekActivities,
      teacherGuidance: editWeekGuidance
    };

    setGeneratedPlan({
      ...generatedPlan,
      sequence: seq
    });
    setEditingWeekIndex(null);
  };

  // One-click Print or Export to text file
  const handleExportTextFile = () => {
    if (!generatedPlan) return;

    const sections = [
      `======================================================`,
      `LOS KALHUÉ — PLATAFORMA TRANSMEDIA EDUCATIVA`,
      `PROYECTO DOCENTE: ${generatedPlan.proposalTitle.toUpperCase()}`,
      `======================================================`,
      `Diseñado para la asignatura: ${subject}`,
      `Nivel Educativo: ${level}`,
      `Duración: ${duration} (${modalidad})`,
      `Estudiantes: ${studentCount} alumnos`,
      `Formato Base: ${activeFormatMeta.name}`,
      `------------------------------------------------------`,
      `1. GANCHO NARRATIVO (LOS KALHUÉ)`,
      generatedPlan.narrativeHook,
      `------------------------------------------------------`,
      `2. VALOR PEDAGÓGICO & COMPETENCIAS`,
      generatedPlan.pedagogicalValue,
      `------------------------------------------------------`,
      `3. INTEGRACIÓN CURRICULAR`,
      generatedPlan.curriculumIntegration,
      `------------------------------------------------------`,
      `4. SECUENCIA DIDÁCTICA DETALLADA`,
      ...generatedPlan.sequence.map(w => 
         `Fase/Semana ${w.week}: ${w.title}\n* Propósito: ${w.description}\n* Alumno (Prosumidor): ${w.studentActivities}\n* Docente (Acompañamiento): ${w.teacherGuidance}\n* Herramientas: ${w.recommendedTools.join(", ")}\n`
      ),
      `------------------------------------------------------`,
      `5. PARÁMETROS DE EVALUACIÓN AUTÉNTICA`,
      `Criterios sugeridos:\n${generatedPlan.evaluationRubric.criteria.map(c => ` - ${c}`).join("\n")}`,
      `Orientaciones de puntajes:\n${generatedPlan.evaluationRubric.scoringGuide}`,
      `------------------------------------------------------`,
      `6. SUGERENCIAS DE EXPANSIÓN TRANSMEDIA`,
      generatedPlan.transmediaExpansion,
      `======================================================`,
      `Exportado automáticamente el: ${new Date().toLocaleDateString()}`
    ].join("\n\n");

    const blob = new Blob([sections], { type: "text/plain;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = `Plan_Los_Kalhue_${theme.slice(0, 15).replace(/\s+/g, '_')}.txt`;
    link.click();
    URL.revokeObjectURL(url);
  };

  // Downloads the complete plan in a beautiful native-styled standalone HTML file,
  // saves the project to "Modo Docente" list so it is permanently archived,
  // and cleans up current page state values.
  const handleDownloadHtmlAndRegister = () => {
    if (!generatedPlan) return;

    // Build the beautiful dark-frequential aesthetic layout resembling the app style
    const htmlContent = `<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Los Kalhué - Dosier Pedagógico: ${generatedPlan.proposalTitle}</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700;950&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg-main: #030d0f;
        --bg-card: #01090a;
        --border-color: #0d1e21;
        --accent-cyan: #06b6d4;
        --accent-yellow: #eab308;
        --accent-emerald: #10b981;
        --text-bright: #f8fafc;
        --text-dim: #94a3b8;
        --text-muted: #475569;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background-color: var(--bg-main);
        color: #cbd5e1;
        font-family: 'Space Grotesk', sans-serif;
        line-height: 1.6;
        padding: 40px 20px;
      }
      .container {
        max-width: 1000px;
        margin: 0 auto;
        background-color: var(--bg-card);
        border: 4px solid var(--border-color);
        padding: 40px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
        position: relative;
      }
      .badge-top {
        position: absolute;
        top: 0;
        right: 0;
        background-color: rgba(6, 182, 212, 0.1);
        color: var(--accent-cyan);
        border-bottom: 2px solid var(--border-color);
        border-left: 2px solid var(--border-color);
        font-size: 8px;
        font-family: 'JetBrains Mono', monospace;
        padding: 6px 14px;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 2px;
      }
      header {
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 25px;
        margin-bottom: 30px;
      }
      h1 {
        font-size: 24px;
        font-weight: 950;
        color: var(--text-bright);
        text-transform: uppercase;
        letter-spacing: -0.5px;
        margin-bottom: 5px;
        line-height: 1.2;
      }
      .subtitle {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        color: var(--accent-cyan);
        text-transform: uppercase;
        letter-spacing: 1px;
      }
      .meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 15px;
        background: rgba(3, 13, 15, 0.6);
        border: 1px solid var(--border-color);
        padding: 20px;
        margin-bottom: 35px;
      }
      .meta-item {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
      }
      .meta-label {
        color: var(--text-dim);
        text-transform: uppercase;
        font-weight: bold;
        display: block;
        margin-bottom: 4px;
      }
      .meta-value {
        color: #e2e8f0;
        font-weight: bold;
      }
      .pillars {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 35px;
      }
      .pillar-card {
        background-color: rgba(3, 13, 15, 0.5);
        border: 1px solid var(--border-color);
        padding: 20px;
      }
      .pillar-title {
        font-size: 11px;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 12px;
        padding-bottom: 6px;
        font-family: 'JetBrains Mono', monospace;
      }
      .pillar-title.yellow { color: var(--accent-yellow); border-bottom: 1px solid rgba(234, 179, 8, 0.3); }
      .pillar-title.cyan { color: var(--accent-cyan); border-bottom: 1px solid rgba(6, 182, 212, 0.3); }
      .pillar-title.emerald { color: var(--accent-emerald); border-bottom: 1px solid rgba(16, 185, 129, 0.3); }
      .pillar-text {
        font-size: 12px;
        color: #cbd5e1;
      }
      h2 {
        font-size: 14px;
        font-weight: 900;
        color: var(--accent-cyan);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 40px 0 20px 0;
        border-bottom: 2px solid var(--border-color);
        padding-bottom: 8px;
        font-family: 'JetBrains Mono', monospace;
      }
      .sequence-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .phase-card {
        background-color: rgba(3, 13, 15, 0.3);
        border: 2px solid var(--border-color);
        padding: 24px;
      }
      .phase-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
      }
      .phase-num {
        background-color: var(--bg-main);
        color: #94a3b8;
        border: 1px solid var(--border-color);
        font-size: 10px;
        font-family: 'JetBrains Mono', monospace;
        font-weight: bold;
        padding: 2px 10px;
      }
      .phase-title {
        font-size: 14px;
        font-weight: bold;
        color: var(--text-bright);
      }
      .phase-desc {
        font-size: 12px;
        font-style: italic;
        color: var(--text-dim);
        margin-bottom: 20px;
      }
      .roles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        border-top: 1px solid var(--border-color);
        padding-top: 15px;
      }
      .role-block {
        font-size: 12px;
      }
      .role-title {
        font-weight: bold;
        color: #e2e8f0;
        display: block;
        margin-bottom: 6px;
      }
      .role-content {
        color: #94a3b8;
      }
      .rubrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
      }
      .rubric-panel {
        background-color: rgba(3, 13, 15, 0.7);
        border: 1px solid var(--border-color);
        padding: 24px;
      }
      .rubric-title {
        font-size: 12px;
        font-weight: bold;
        text-transform: uppercase;
        color: var(--text-bright);
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        margin-bottom: 15px;
        font-family: 'JetBrains Mono', monospace;
      }
      .crit-list {
        list-style: none;
        margin-bottom: 20px;
      }
      .crit-list li {
        font-size: 12px;
        position: relative;
        padding-left: 15px;
        margin-bottom: 8px;
        color: #cbd5e1;
      }
      .crit-list li::before {
        content: "◆";
        position: absolute;
        left: 0;
        color: var(--accent-cyan);
        font-size: 8px;
      }
      .guide-panel {
        font-size: 11px;
        background-color: var(--bg-main);
        padding: 12px;
        border-left: 2px solid var(--accent-cyan);
        font-style: italic;
        color: #cbd5e1;
      }
      footer {
        margin-top: 60px;
        text-align: center;
        border-top: 2px solid var(--border-color);
        padding-top: 25px;
        font-family: 'JetBrains Mono', monospace;
        font-size: 10px;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 2px;
      }
    </style>
</head>
<body>
    <div class="container">
        <div class="badge-top">Sintonización Pedagógica Transmedia</div>
        
        <header>
            <h1>${generatedPlan.proposalTitle}</h1>
            <div class="subtitle">Diseñado con el lore de Los Kalhué</div>
        </header>

        <div class="meta-grid">
            <div class="meta-item">
                <span class="meta-label">Materia</span>
                <span class="meta-value">${subject || 'General'}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Tema</span>
                <span class="meta-value">${theme || 'General'}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Nivel</span>
                <span class="meta-value">${level}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Duración</span>
                <span class="meta-value">${duration}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Formato Principal</span>
                <span class="meta-value">${activeFormatMeta.name}</span>
            </div>
            <div class="meta-item">
                <span class="meta-label">Estudiantes</span>
                <span class="meta-value">${studentCount}</span>
            </div>
        </div>

        <div class="pillars">
            <div class="pillar-card">
                <div class="pillar-title yellow">⚡ Gancho Narrativo (Mitología)</div>
                <p class="pillar-text">${generatedPlan.narrativeHook}</p>
            </div>
            <div class="pillar-card">
                <div class="pillar-title cyan">🌸 Valor Pedagógico XXI</div>
                <p class="pillar-text">${generatedPlan.pedagogicalValue}</p>
            </div>
            <div class="pillar-card">
                <div class="pillar-title emerald">🎯 Integración Curricular</div>
                <p class="pillar-text">${generatedPlan.curriculumIntegration}</p>
            </div>
        </div>

        <h2>Secuencia Didáctica Paso a Paso</h2>
        <div class="sequence-container">
            ${generatedPlan.sequence.map((w, idx) => `
            <div class="phase-card">
                <div class="phase-header">
                    <span class="phase-num">FASE ${w.week || (idx + 1)}</span>
                    <span class="phase-title">${w.title}</span>
                </div>
                <p class="phase-desc">${w.description}</p>
                <div class="roles-grid">
                    <div class="role-block">
                        <span class="role-title">💻 Prosumidores (Estudiantes):</span>
                        <div class="role-content">${w.studentActivities}</div>
                    </div>
                    <div class="role-block">
                        <span class="role-title">🧑🏻‍🏫 Facilitador (Tutor):</span>
                        <div class="role-content">${w.teacherGuidance}</div>
                    </div>
                </div>
            </div>
            `).join('')}
        </div>

        <h2>Evaluación Auténtica & Expansiones</h2>
        <div class="rubrics-grid">
            <div class="rubric-panel">
                <div class="rubric-title">Rúbricas de Evaluación</div>
                <ul class="crit-list">
                    ${generatedPlan.evaluationRubric.criteria.map(cr => `<li>${cr}</li>`).join('')}
                </ul>
                <div class="guide-panel">
                    <strong>Guía de Puntuación:</strong> ${generatedPlan.evaluationRubric.scoringGuide}
                </div>
            </div>
            
            <div class="pillar-card" style="display:flex; flex-direction:column; justify-content:space-between;">
                <div>
                    <div class="pillar-title cyan" style="border-bottom:1px solid var(--border-color); padding-bottom:10px; margin-bottom:15px;">Expansión Transmedia Sugerida</div>
                    <p class="pillar-text" style="font-size:12px; line-height:1.5; color:#cbd5e1;">${generatedPlan.transmediaExpansion}</p>
                </div>
                <div style="background-color: var(--bg-main); font-size:10px; color:#94a3b8; border:1px solid var(--border-color); padding:10px; margin-top:15px; font-family:'JetBrains Mono', monospace; font-style: italic;">
                    <strong>Criterio de Jenkins:</strong> El prosumidor expande alternativamente de forma horizontal (redes sismológicas) e inmersiva (profundidad narrativa).
                </div>
            </div>
        </div>

        <footer>
            Estación Sismológica Kalhué • La Pampa, ARG • Generado automáticamente el ${new Date().toLocaleDateString()}
        </footer>
    </div>
</body>
</html>`;

    // Trigger dynamic browser download of HTML
    const blob = new Blob([htmlContent], { type: "text/html;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = `Orientaciones_Didacticas_Kalhue_${theme.slice(0, 15).replace(/\s+/g, '_') || 'Plan'}.html`;
    link.click();
    URL.revokeObjectURL(url);

    // Register project in local database
    const newProject: SavedProject = {
      id: `proj_${Date.now()}`,
      theme,
      subject,
      level,
      duration,
      primaryFormat: activeFormatMeta.name,
      createdAt: new Date().toLocaleDateString(),
      plan: generatedPlan
    };

    onProjectSaved(newProject);
    alert("✨ ¡Propuesta de Orientaciones registrada con éxito en tu Dosier de 'Modo Docente' y descargada en formato HTML premium!");

    // Clean/clear active form state and preview so it is fresh for next use
    setTheme("");
    setSubject("");
    setGeneratedPlan(null);
  };

  return (
    <div id="project-planner-view" className="space-y-8 font-mono text-slate-300">
      
      {/* Upper Grid Layout: Parameters Input form vs Selected format details panel */}
      <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        {/* Left half: Form Inputs (7 Cols) */}
        <form onSubmit={handleGeneratePlan} className="lg:col-span-7 bg-slate-950 p-5 border-2 border-slate-900 rounded-none shadow-xl space-y-4">
          <div className="border-b border-slate-900 pb-2 mb-2 flex justify-between items-center">
            <div>
              <h4 className="text-xs font-black tracking-widest text-slate-400 uppercase flex items-center gap-1.5">
                <Sparkles className="h-4 w-4 text-cyan-400" />
                <span>DISEÑADOR DE PROYECTOS TRANSMEDIA</span>
              </h4>
              <p className="text-[9px] text-slate-600">Andamiaje de inteligencia artificial para profesores</p>
            </div>
          </div>

          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {/* Theme */}
            <div className="flex flex-col gap-1 sm:col-span-2">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Tema o Concepto a enseñar:</label>
              <input
                type="text"
                value={theme}
                onChange={(e) => setTheme(e.target.value)}
                placeholder="Ej. Normas de convivencia escolar, La fotosíntesis bioluminica, etc."
                required
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-100"
              />
            </div>

            {/* Subject / Materia */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Materia o Asignatura:</label>
              <input
                type="text"
                value={subject}
                onChange={(e) => setSubject(e.target.value)}
                placeholder="Ej. Lengua, Biología, Cívica"
                required
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-100"
              />
            </div>

            {/* Educational Level */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Nivel Educativo:</label>
              <select
                value={level}
                onChange={(e) => setLevel(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-200 cursor-pointer"
              >
                <option value="Secundaria Básica (12-15 años)">Secundaria Básica (12-15 años)</option>
                <option value="Secundaria Superior (16-18 años)">Secundaria Superior (16-18 años)</option>
                <option value="Terciario o Universitario">Terciario o Universitario</option>
              </select>
            </div>

            {/* Duration */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Duración del Proyecto:</label>
              <select
                value={duration}
                onChange={(e) => setDuration(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-200 cursor-pointer"
              >
                <option value="2 semanas (fases rápidas)">2 semanas (fases rápidas)</option>
                <option value="3 semanas (duración media)">3 semanas (duración media)</option>
                <option value="4 semanas (proyecto estándar)">4 semanas (proyecto estándar)</option>
                <option value="5 semanas (secuencia extendida)">5 semanas (secuencia extendida)</option>
              </select>
            </div>

            {/* Student Count */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Estudiantes en Clase:</label>
              <input
                type="number"
                min="5"
                max="100"
                value={studentCount}
                onChange={(e) => setStudentCount(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-100"
              />
            </div>

            {/* Primary Format Selector */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Formato Principal Transmedia:</label>
              <select
                value={primaryFormat}
                onChange={(e) => setPrimaryFormat(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-200 cursor-pointer"
              >
                {TRANSMEDIA_FORMATS.map(f => (
                  <option key={f.id} value={f.id}>{f.name}</option>
                ))}
              </select>
            </div>

            {/* Modality */}
            <div className="flex flex-col gap-1">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Modalidad sugerida:</label>
              <input
                type="text"
                value={modalidad}
                onChange={(e) => setModalidad(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-100"
              />
            </div>

            {/* Classroom Resources */}
            <div className="flex flex-col gap-1 sm:col-span-2">
              <label className="text-[10px] text-slate-400 uppercase font-bold">Recursos Tecnológicos disponibles:</label>
              <input
                type="text"
                value={resources}
                onChange={(e) => setResources(e.target.value)}
                className="bg-slate-900 border border-slate-800 focus:border-slate-700 outline-none rounded py-2 px-3 text-xs text-slate-100"
              />
            </div>
          </div>

          <div className="pt-3 flex gap-4">
            <button
              type="submit"
              disabled={isLoading || !theme.trim() || !subject.trim()}
              className="flex-1 py-3 bg-cyan-600 hover:bg-cyan-500 active:bg-cyan-600 text-slate-950 font-black text-xs tracking-widest rounded transition flex items-center justify-center gap-2 cursor-pointer disabled:opacity-40"
            >
              {isLoading ? (
                <>
                  <div className="h-4 w-4 border-2 border-slate-950 border-t-transparent animate-spin rounded-full" />
                  <span>DECODIFICANDO SECUENCIA...</span>
                </>
              ) : (
                <>
                  <Sparkles className="h-4 w-4 fill-slate-950" />
                  <span>EMITIR PROPUESTA EN EL CAMPO</span>
                </>
              )}
            </button>
          </div>
        </form>

        {/* Right half: Format information display panel (5 Cols) */}
        <div className="lg:col-span-5 bg-slate-900/40 border border-slate-900 p-5 rounded-md flex flex-col justify-between">
          <div>
            <div className="text-[8px] text-cyan-400 font-bold tracking-widest uppercase mb-1">
              Format de Expansión Seleccionado
            </div>
            <h3 className="text-sm font-semibold text-slate-100 flex items-center gap-2">
              <span className="text-xs px-2 py-0.5 bg-cyan-500/15 text-cyan-400 border border-cyan-500/30 font-bold uppercase rounded">
                {activeFormatMeta.complexity}
              </span>
              <span>{activeFormatMeta.name}</span>
            </h3>
            
            <p className="text-xxs text-slate-400 leading-relaxed mt-3 border-l-2 border-cyan-500/60 pl-3">
              {activeFormatMeta.definition}
            </p>

            <div className="text-[10px] space-y-2.5 mt-5">
              <div>
                <strong>Potencial Pedagógico:</strong>
                <span className="text-slate-400 block mt-0.5 leading-normal">{activeFormatMeta.pedagogicalPotential}</span>
              </div>
              <div className="grid grid-cols-2 gap-4 border-t border-slate-800/80 pt-3">
                <div>
                  <strong>Habilidades:</strong>
                  <div className="flex flex-wrap gap-1 mt-1">
                    {activeFormatMeta.skillsInvolved.map((sk, idx) => (
                      <span key={idx} className="bg-slate-950 px-1.5 py-0.5 text-[8px] text-slate-500 rounded border border-slate-850">
                        {sk}
                      </span>
                    ))}
                  </div>
                </div>
                <div>
                  <strong>Herramientas:</strong>
                  <div className="flex flex-wrap gap-1 mt-1">
                    {activeFormatMeta.recommendedTools.map((tool, idx) => (
                      <span key={idx} className="bg-cyan-500/5 px-1.5 py-0.5 text-[8px] text-cyan-400 rounded border border-cyan-500/10">
                        {tool}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <div className="border-t border-slate-800/80 pt-3 mt-4 text-[9px] text-slate-500 flex items-center gap-2">
            <Clock className="h-3 w-3 text-slate-600" />
            <span>Tiempo promedio de producción colectiva: {activeFormatMeta.duration}</span>
          </div>
        </div>

      </div>

      {/* LOWER PANEL: PLANIFY OUTPUT SCREEN */}
      {generatedPlan && (
        <div id="plan-generation-outcome" className="bg-slate-950 border-4 border-slate-900 rounded-none p-5 lg:p-6 shadow-2xl relative">
          
          {/* Aesthetic tags */}
          <div className="absolute -top-3.5 right-6 bg-yellow-500 text-slate-950 text-[9px] font-black px-3 py-1 uppercase tracking-widest border border-slate-950">
            Sintonización Exitosa
          </div>

          {/* Export & Save Toolbar */}
          <div className="flex flex-wrap items-center justify-between border-b border-slate-800 pb-3.5 mb-6 gap-4">
            <div>
              <span className="text-[9px] text-cyan-500 uppercase font-black">Planificador Curricular Modular</span>
              <h2 className="text-lg font-black text-slate-100 mt-0.5 flex items-center gap-2">
                <span>{generatedPlan.proposalTitle}</span>
              </h2>
            </div>

            <div className="flex flex-wrap gap-3">
              {/* Dual Action: Download beautifully styled HTML, Register to Dossier, and Clean workspace */}
              <button
                type="button"
                onClick={handleDownloadHtmlAndRegister}
                className="py-1.5 px-4 bg-cyan-500 hover:bg-cyan-400 active:bg-cyan-500 text-slate-950 font-black text-xxs tracking-wider transition rounded cursor-pointer flex items-center gap-1.5 shadow-lg shadow-cyan-500/15"
                title="Descarga en un archivo HTML de diseño interactivo y guarda en el Dosier Docente para limpiar el tablero"
              >
                <Download className="h-3 w-3" />
                <span>DESCARGAR HTML Y REGISTRAR</span>
              </button>

              {/* Save Project locally without cleaning */}
              <button
                type="button"
                onClick={handleSaveToMyDossier}
                className="py-1.5 px-4 bg-emerald-600/20 border border-emerald-500/30 text-emerald-400 hover:text-emerald-300 font-bold text-xxs tracking-wider transition rounded cursor-pointer"
              >
                SÓLO REGISTRAR
              </button>
              
              {/* Export TXT */}
              <button
                type="button"
                onClick={handleExportTextFile}
                className="py-1.5 px-3 bg-slate-900 border border-slate-800 text-slate-400 hover:text-slate-100 font-bold text-xxs tracking-wider transition flex items-center gap-1.5 cursor-pointer"
              >
                <Download className="h-3 w-3" />
                <span>EXP_TXT</span>
              </button>

              {/* Print layout */}
              <button
                type="button"
                onClick={() => window.print()}
                className="py-1.5 px-3 bg-slate-900 border border-slate-800 text-slate-400 hover:text-slate-100 font-bold text-xxs tracking-wider transition flex items-center gap-1.5 cursor-pointer"
              >
                <Printer className="h-3 w-3" />
                <span>IMPRIMIR</span>
              </button>
            </div>
          </div>

          {/* Master layout details card rows (Gancho, Competencias, Integración) */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            
            {/* Hook */}
            <div className="p-4 bg-slate-900/50 border border-slate-900 rounded-md">
              <strong className="text-yellow-500 text-xxs tracking-wider uppercase block border-b border-slate-850 pb-1 mb-2">
                ⚡ Gancho Narrativo (Mitología)
              </strong>
              <p className="text-xxs text-slate-300 leading-relaxed">
                {generatedPlan.narrativeHook}
              </p>
            </div>

            {/* Pedagogical */}
            <div className="p-4 bg-slate-900/50 border border-slate-900 rounded-md">
              <strong className="text-cyan-400 text-xxs tracking-wider uppercase block border-b border-slate-850 pb-1 mb-2">
                🌸 Valor Pedagógico XXI
              </strong>
              <p className="text-xxs text-slate-300 leading-relaxed">
                {generatedPlan.pedagogicalValue}
              </p>
            </div>

            {/* Curriculum */}
            <div className="p-4 bg-slate-900/50 border border-slate-900 rounded-md">
              <strong className="text-emerald-400 text-xxs tracking-wider uppercase block border-b border-slate-850 pb-1 mb-2">
                🎯 Integración Curricular
              </strong>
              <p className="text-xxs text-slate-300 leading-relaxed">
                {generatedPlan.curriculumIntegration}
              </p>
            </div>

          </div>

          {/* Sequential Phases / Week roadmaps */}
          <div className="space-y-4 mb-8">
            <h3 className="text-xs font-black text-slate-400 border-b border-slate-800 pb-2 mb-4 uppercase tracking-widest">
              Secuencia Didáctica Paso a Paso
            </h3>

            {/* Editing Box Overlay */}
            {editingWeekIndex !== null && (
              <div className="bg-slate-900 border-2 border-yellow-500/60 p-4 rounded-md mb-4 space-y-3.5">
                <div className="flex justify-between items-center text-xs font-bold text-yellow-500">
                  <span>Modificando Fase {editingWeekIndex + 1}</span>
                  <button onClick={() => setEditingWeekIndex(null)} className="text-xxs text-slate-500 hover:text-slate-300">
                    Cancelar
                  </button>
                </div>
                <div className="flex flex-col gap-1.5">
                  <span className="text-xxs text-slate-400 uppercase">Título de la Fase:</span>
                  <input
                    type="text"
                    value={editWeekTitle}
                    onChange={(e) => setEditWeekTitle(e.target.value)}
                    className="bg-slate-950 border border-slate-800 py-1.5 px-3 rounded text-xs text-slate-100"
                  />
                </div>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div className="flex flex-col gap-1.5">
                    <span className="text-xxs text-slate-400 uppercase">Actividades del Estudiante (Prosumidor):</span>
                    <textarea
                      value={editWeekActivities}
                      onChange={(e) => setEditWeekActivities(e.target.value)}
                      rows={3}
                      className="bg-slate-950 border border-slate-800 py-1.5 px-3 rounded text-xs text-slate-100"
                    />
                  </div>
                  <div className="flex flex-col gap-1.5">
                    <span className="text-xxs text-slate-400 uppercase">Andamiaje del Facilitador (Ernesto):</span>
                    <textarea
                      value={editWeekGuidance}
                      onChange={(e) => setEditWeekGuidance(e.target.value)}
                      rows={3}
                      className="bg-slate-950 border border-slate-800 py-1.5 px-3 rounded text-xs text-slate-100"
                    />
                  </div>
                </div>
                <button
                  type="button"
                  onClick={handleSaveWeekChanges}
                  className="py-1 px-4 bg-yellow-500 text-slate-950 font-bold text-xxs transition cursor-pointer"
                >
                  Guardar Cambios Locales
                </button>
              </div>
            )}

            <div className="space-y-4">
              {generatedPlan.sequence.map((w, idx) => (
                <div key={idx} className="bg-slate-900/25 border-2 border-slate-900 rounded p-4 relative group flex flex-col md:flex-row gap-4 justify-between">
                  <div className="flex-1 space-y-2">
                    <div className="flex items-center gap-2">
                      <span className="text-[9px] px-2 py-0.5 bg-slate-950 text-slate-400 font-extrabold rounded border border-slate-800">
                        {w.week ? `FASE ${w.week}` : `FASE ${idx + 1}`}
                      </span>
                      <h4 className="text-xs font-black text-slate-100">{w.title}</h4>
                    </div>

                    <p className="text-xxs text-slate-400 italic leading-relaxed">
                      {w.description}
                    </p>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 text-xxs border-t border-slate-900/60 pt-2.5">
                      <div>
                        <strong className="text-slate-200 block mb-0.5">💻 Prosumidores (Estudiantes):</strong>
                        <span className="text-slate-400 leading-normal block">{w.studentActivities}</span>
                      </div>
                      <div>
                        <strong className="text-slate-200 block mb-0.5">🧑🏻‍🏫 Facilitador (Tutor):</strong>
                        <span className="text-slate-400 leading-normal block">{w.teacherGuidance}</span>
                      </div>
                    </div>
                  </div>

                  {/* Actions (Edit phase card) */}
                  <div className="flex flex-row md:flex-col items-center justify-end gap-2 shrink-0 border-t md:border-t-0 md:border-l border-slate-900/80 pt-2.5 md:pt-0 md:pl-4">
                    <button
                      type="button"
                      onClick={() => handleEditWeek(idx)}
                      className="p-1 px-2 hover:bg-slate-800 border border-slate-850 hover:border-slate-700 rounded text-slate-400 hover:text-slate-200 text-[10px] flex items-center gap-1 transition cursor-pointer"
                    >
                      <Edit2 className="h-3 w-3" />
                      <span>EDITAR</span>
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Rubrics & transmedia expansions parameters card bottom */}
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-slate-800 pt-6">
            
            {/* Rubrics parameters */}
            <div className="p-4 bg-slate-950 border border-slate-900 rounded-md">
              <strong className="text-xxs tracking-wider uppercase block text-slate-200 border-b border-slate-900 pb-1.5 mb-2.5">
                Evaluación Auténtica & Rúbricas
              </strong>
              <div className="space-y-3 font-mono text-xxs text-slate-400 leading-relaxed">
                <div>
                  <strong className="text-slate-300 block mb-1">Criterios de Evaluación:</strong>
                  <ul className="list-disc list-inside space-y-1 block pl-2">
                    {generatedPlan.evaluationRubric.criteria.map((cr, idx) => (
                      <li key={idx}>{cr}</li>
                    ))}
                  </ul>
                </div>
                <div className="border-t border-slate-900 pt-2 text-[10px] italic">
                  <strong>Guía de puntuación:</strong> {generatedPlan.evaluationRubric.scoringGuide}
                </div>
              </div>
            </div>

            {/* Orbit transmedia formats suggested options */}
            <div className="p-4 bg-slate-950 border border-slate-900 rounded-md flex flex-col justify-between">
              <div>
                <strong className="text-xxs tracking-wider uppercase block text-slate-200 border-b border-slate-900 pb-1.5 mb-2.5">
                  Orbitadores de la Frecuencia (Formato Multi-Medios)
                </strong>
                <p className="text-xxs text-slate-400 leading-relaxed">
                  {generatedPlan.transmediaExpansion}
                </p>
              </div>

              <div className="bg-slate-900/50 p-2 text-[9px] text-slate-500 border border-slate-900/70 rounded mt-3">
                ⭐ <strong>Criterio de Jenkins</strong>: El prosumidor expande alternativamente de forma horizontal (redes sismológicas) e inmersa (profundidad del lore).
              </div>
            </div>

          </div>

        </div>
      )}

    </div>
  );
}
